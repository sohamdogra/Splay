# Arvya Social Agent application environment template
# Copy to .env and keep all secrets local.

# API
API_HOST=127.0.0.1
API_PORT=4173
API_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# Required whenever API_HOST is not a loopback address. When set, private reads
# and all mutations require Authorization: Bearer <token>.
# ARVYA_API_TOKEN=
# API_BODY_LIMIT_BYTES=2097152

# Output and test mode
# SOCIAL_AGENT_OUTPUT_DIR=/absolute/path/to/output
# SOCIAL_AGENT_TEST_MODE=1

# GBrain context
# The app defaults to scripts/local-gbrain-mcp.py, which reads only the public-safe
# allowlist in the local checkout. Set GBRAIN_USE_MOCK=1 for deterministic demos.
# GBRAIN_USE_MOCK=1
# GBRAIN_CONTEXT_FILE=scripts/runtime/src/data/mockGbrainContext.json
# GBRAIN_MCP_HTTP_URL=http://localhost:8787/mcp
# GBRAIN_MCP_BRIDGE_PATH=/absolute/path/to/a/credential-free-mcp-bridge.py
# GBRAIN_LOCAL_REPO=/absolute/path/to/.gbrain-cache
# GBRAIN_LOCAL_MAX_STALENESS_HOURS=48
# GBRAIN_MCP_TIMEOUT_MS=20000
# GBRAIN_MCP_SEARCH_METHOD=searchCompanyContext
# GBRAIN_MCP_RECENT_UPDATES_METHOD=getRecentUpdates
# GBRAIN_MCP_CUSTOMER_INSIGHTS_METHOD=getRecentCustomerInsights
# GBRAIN_MCP_PRODUCT_NOTES_METHOD=getRecentProductNotes
# GBRAIN_MCP_SALES_OBJECTIONS_METHOD=getRecentSalesObjections

# Text generation
# Without a model key, the application uses deterministic local generation.
# SOCIAL_AGENT_USE_MOCK_LLM=1
# SOCIAL_AGENT_CREATIVE_MODE=1
# SOCIAL_AGENT_UNIQUE_IMAGES_PER_POST=1
# SOCIAL_AGENT_TEXT_TEMPERATURE=0.95
# OPENAI_API_KEY=
# OPENAI_TEXT_MODEL=gpt-4.1-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_TEXT_MODEL=claude-3-5-sonnet-latest

# Image generation and deterministic composition
# SOCIAL_AGENT_IMAGE_MODE=canva
# SOCIAL_AGENT_IMAGE_MODE=gpt-canva
# SOCIAL_AGENT_IMAGE_MODE=placeholder
# SOCIAL_AGENT_CREATIVE_IMAGE_MODE=gpt-canva
# ARVYA_REFERENCE_ASSET_DIR=/absolute/path/to/reference/assets
# OPENAI_IMAGE_MODEL=gpt-image-2
# OPENAI_IMAGE_SIZE=1536x1024
# OPENAI_IMAGE_QUALITY=medium
# OPENAI_IMAGE_FORMAT=png
# SOCIAL_AGENT_GPT_BACKGROUND_CANDIDATES=2

# Buffer publishing
# BUFFER_API_KEY=
# BUFFER_LINKEDIN_PROFILE_IDS=
# BUFFER_X_PROFILE_IDS=
# BUFFER_PROFILE_IDS=
# BUFFER_PUBLISH_MODE=queue
# BUFFER_API_URL=https://api.buffer.com
# BUFFER_GRAPHQL_ENDPOINT=
# LINKEDIN_MENTION_REGISTRY_PATH=/absolute/path/to/linkedin-mentions.json

# Cloudflare R2 media hosting
# Buffer needs a durable public HTTPS URL for local post media.
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=arvya-images
# R2_PUBLIC_BASE_URL=https://media.example.com

# Database-backed metrics and feedback
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require
# DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# DATABASE_CA_CERT_PATH=scripts/runtime/prod-ca-2021.crt

# Brand defaults
BRAND_NAME=Arvya
BRAND_AUDIENCE=private equity, investment banking, deal teams, founders, operators
BRAND_TONE=sharp, credible, founder-led, direct, thoughtful
