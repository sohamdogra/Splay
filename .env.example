# Splay application environment template
# Copy to .env and keep all secrets local.

# API
API_HOST=127.0.0.1
API_PORT=4173
API_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173
# Required whenever API_HOST is not a loopback address. When set, private reads
# and all mutations require Authorization: Bearer <token>.
# SPLAY_API_TOKEN=
# API_BODY_LIMIT_BYTES=2097152

# Output and test mode
# SOCIAL_AGENT_OUTPUT_DIR=/absolute/path/to/output
# SOCIAL_AGENT_TEST_MODE=1

# Company context is stored by the application in output/company-brain.json.
# Add it through Brand & brain in the frontend or POST /api/v1/brain/context.
# Only records explicitly marked public-safe are used during generation.

# Text generation
# These keys are used for text only. Without one, the application uses
# deterministic local generation.
# SOCIAL_AGENT_USE_MOCK_LLM=1
# SOCIAL_AGENT_CREATIVE_MODE=1
# SOCIAL_AGENT_UNIQUE_IMAGES_PER_POST=1
# SOCIAL_AGENT_TEXT_TEMPERATURE=0.95
# OPENAI_API_KEY=
# OPENAI_TEXT_MODEL=gpt-4.1-mini
# ANTHROPIC_API_KEY=
# ANTHROPIC_TEXT_MODEL=claude-3-5-sonnet-latest

# TokenMart media generation and deterministic composition
# SOCIAL_AGENT_IMAGE_MODE=canva
# SOCIAL_AGENT_IMAGE_MODE=tokenmart-canva
# SOCIAL_AGENT_IMAGE_MODE=placeholder
# SOCIAL_AGENT_CREATIVE_IMAGE_MODE=tokenmart-canva
# SPLAY_REFERENCE_ASSET_DIR=/absolute/path/to/reference/assets
# TOKENMART_API_KEY=sk-inf-v1-...
# TOKENMART_BASE_URL=https://model.service-inference.ai
# TOKENMART_IMAGE_MODEL=dola-seedream-5-0-pro-260628
# TOKENMART_IMAGE_SIZE=1280x720
# TOKENMART_VIDEO_MODEL=dreamina-seedance-2-0-260128
# TOKENMART_BACKGROUND_CANDIDATES=2
# TOKENMART_MAX_RETRIES=2
# TOKENMART_REQUEST_TIMEOUT_MS=300000
# TOKENMART_VIDEO_POLL_INTERVAL_MS=5000
# TOKENMART_VIDEO_TIMEOUT_MS=600000

# Buffer publishing
# BUFFER_API_KEY=
# BUFFER_LINKEDIN_PROFILE_IDS=
# BUFFER_X_PROFILE_IDS=
# BUFFER_PROFILE_IDS=
# BUFFER_PUBLISH_MODE=queue
# BUFFER_API_URL=https://api.buffer.com
# BUFFER_GRAPHQL_ENDPOINT=
# LINKEDIN_MENTION_REGISTRY_PATH=/absolute/path/to/linkedin-mentions.json

# Convex file storage
# CONVEX_URL is written to .env.local by `npm run convex:dev`.
# Use the same high-entropy token locally and in the Convex deployment environment.
# CONVEX_URL=https://<deployment>.convex.cloud
# CONVEX_INGEST_TOKEN=
# CONVEX_DEPLOYMENT=dev:<deployment-name>
# CI/deployment only; never expose this key to a frontend.
# CONVEX_DEPLOY_KEY=

# Database-backed metrics and feedback
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true&sslmode=require
# DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/postgres?sslmode=require
# DATABASE_CA_CERT_PATH=scripts/runtime/prod-ca-2021.crt

# Brand defaults
BRAND_NAME=Splay
# BRAND_AUDIENCE=
# BRAND_TONE=clear, specific, credible

# Optional verified LinkedIn organization identity for automatic brand mentions
# LINKEDIN_BRAND_ORGANIZATION_ID=your-organization-id
# LINKEDIN_BRAND_VANITY_NAME=your-company-vanity-name
# LINKEDIN_BRAND_LOCALIZED_NAME=Splay
# LINKEDIN_BRAND_URL=https://www.linkedin.com/company/your-company-vanity-name
