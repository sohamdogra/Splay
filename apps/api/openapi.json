{
  "openapi": "3.1.0",
  "info": {
    "title": "Splay API",
    "version": "0.2.0",
    "description": "Local-first application API for generation, review, scheduling, publishing, metrics, and frontend media access."
  },
  "servers": [
    { "url": "http://127.0.0.1:4173" }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "Error": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "required": ["code", "message", "request_id"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "request_id": { "type": "string" }
            }
          }
        }
      },
      "Job": {
        "type": "object",
        "required": ["id", "kind", "status", "created_at", "output"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "kind": { "type": "string", "enum": ["generate", "campaign-generate", "animate-background", "publish-approved", "metrics-collect", "metrics-score", "feedback-generate"] },
          "status": { "type": "string", "enum": ["queued", "running", "succeeded", "failed", "cancelled"] },
          "metadata": { "type": "object" },
          "created_at": { "type": "string", "format": "date-time" },
          "started_at": { "type": "string", "format": "date-time" },
          "finished_at": { "type": "string", "format": "date-time" },
          "exit_code": { "type": "integer" },
          "output": { "type": "string" },
          "error": { "type": "string" }
        }
      },
      "Campaign": {
        "type": "object",
        "required": ["id", "name", "brief", "platforms", "start_at", "timezone", "interval_weeks", "occurrences", "status", "slots"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "name": { "type": "string" },
          "brief": { "type": "string" },
          "themes": { "type": "array", "items": { "type": "string" } },
          "platforms": { "type": "array", "items": { "type": "string", "enum": ["linkedin", "x"] } },
          "start_at": { "type": "string", "format": "date-time" },
          "timezone": { "type": "string", "example": "America/Los_Angeles" },
          "interval_weeks": { "type": "integer", "minimum": 1, "maximum": 4 },
          "occurrences": { "type": "integer", "minimum": 2, "maximum": 52 },
          "creative": { "type": "boolean" },
          "status": { "type": "string", "enum": ["draft", "generating", "active", "paused", "completed"] },
          "slots": { "type": "array", "items": { "type": "object" } }
        }
      },
      "BrandKit": {
        "type": "object",
        "required": ["name", "tagline", "audience", "tone", "positioning", "avoid", "colors", "typography"],
        "properties": {
          "version": { "type": "integer" },
          "name": { "type": "string" },
          "tagline": { "type": "string" },
          "audience": { "type": "string" },
          "tone": { "type": "string" },
          "positioning": { "type": "string" },
          "avoid": { "type": "array", "items": { "type": "string" } },
          "colors": { "type": "object" },
          "typography": { "type": "object" },
          "logo_url": { "type": ["string", "null"] }
        }
      },
      "CompanyContextItem": {
        "type": "object",
        "required": ["id", "title", "kind", "summary", "tags", "public_safe", "created_at", "updated_at"],
        "properties": {
          "id": { "type": "string", "format": "uuid" },
          "title": { "type": "string", "maxLength": 160 },
          "kind": { "type": "string", "maxLength": 80 },
          "summary": { "type": "string", "maxLength": 4000 },
          "source": { "type": "string", "maxLength": 500 },
          "date": { "type": "string", "format": "date-time" },
          "tags": { "type": "array", "maxItems": 20, "items": { "type": "string" } },
          "public_safe": { "type": "boolean", "default": false },
          "created_at": { "type": "string", "format": "date-time" },
          "updated_at": { "type": "string", "format": "date-time" }
        }
      }
    }
  },
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/api/v1/health": {
      "get": {
        "summary": "Read service health and provider readiness",
        "security": [],
        "responses": { "200": { "description": "Service health" }, "503": { "description": "Output storage is not writable" } }
      }
    },
    "/api/v1/openapi.json": {
      "get": {
        "summary": "Read this API contract",
        "security": [],
        "responses": { "200": { "description": "OpenAPI document" } }
      }
    },
    "/api/v1/posts": {
      "get": {
        "summary": "List posts",
        "parameters": [
          { "name": "platform", "in": "query", "schema": { "type": "string", "enum": ["linkedin", "x"] } },
          { "name": "status", "in": "query", "schema": { "type": "string", "enum": ["draft", "approved", "rejected", "staged", "posted", "failed"] } }
        ],
        "responses": { "200": { "description": "Post collection" } }
      }
    },
    "/api/v1/posts/{id}": {
      "get": {
        "summary": "Read one post",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Post" }, "404": { "description": "Not found" } }
      }
    },
    "/api/v1/posts/{id}/decisions": {
      "post": {
        "summary": "Approve, revise, or reject a post",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["decision", "reason"],
                "properties": {
                  "decision": { "type": "string", "enum": ["approve", "revise", "reject"] },
                  "reason": { "type": "string" },
                  "note": { "type": "string", "maxLength": 2000 }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated post" }, "422": { "description": "Editorial gate rejected the mutation" } }
      }
    },
    "/api/v1/posts/{id}/schedule": {
      "put": {
        "summary": "Set or clear an explicit schedule",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["scheduled_for"],
                "properties": {
                  "scheduled_for": { "type": ["string", "null"], "format": "date-time" }
                }
              }
            }
          }
        },
        "responses": { "200": { "description": "Updated post" }, "422": { "description": "Invalid schedule" } }
      }
    },
    "/api/v1/campaigns": {
      "get": { "summary": "List recurring campaigns and their future weekly slots", "responses": { "200": { "description": "Campaign collection" } } },
      "post": {
        "summary": "Create a recurring campaign",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Campaign" } } } },
        "responses": { "201": { "description": "Campaign created" }, "400": { "description": "Invalid campaign" } }
      }
    },
    "/api/v1/campaigns/{id}": {
      "get": { "summary": "Read a campaign", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Campaign" }, "404": { "description": "Not found" } } },
      "patch": { "summary": "Pause, resume, or complete a campaign", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "200": { "description": "Updated campaign" } } }
    },
    "/api/v1/campaigns/{id}/generate": {
      "post": { "summary": "Generate reviewable drafts for every future campaign slot", "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }], "responses": { "202": { "description": "Campaign generation queued" }, "422": { "description": "Campaign start elapsed" } } }
    },
    "/api/v1/brand-kit": {
      "get": { "summary": "Read the active brand kit", "responses": { "200": { "description": "Brand kit" } } },
      "put": { "summary": "Save a new version of the brand kit", "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/BrandKit" } } } }, "responses": { "200": { "description": "Saved brand kit" } } }
    },
    "/api/v1/brain/context": {
      "get": { "summary": "List project-local company context", "responses": { "200": { "description": "Company context collection" } } },
      "post": {
        "summary": "Add a project-local company context record",
        "description": "Records are excluded from generation unless public_safe is explicitly true.",
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CompanyContextItem" } } } },
        "responses": { "201": { "description": "Context record created" }, "400": { "description": "Invalid context record" } }
      }
    },
    "/api/v1/brain/context/{id}": {
      "delete": {
        "summary": "Delete a company context record",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "204": { "description": "Context record deleted" }, "404": { "description": "Not found" } }
      }
    },
    "/api/v1/jobs": {
      "get": {
        "summary": "List recent background jobs",
        "responses": { "200": { "description": "Job collection" } }
      }
    },
    "/api/v1/jobs/{id}": {
      "get": {
        "summary": "Read background job state and bounded output",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Job" }, "404": { "description": "Not found" } }
      }
    },
    "/api/v1/jobs/generate": {
      "post": {
        "summary": "Queue automatic or topic-based generation",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "mode": { "type": "string", "enum": ["auto", "topic"], "default": "auto" },
                  "topic": { "type": "string", "maxLength": 500 },
                  "creative": { "type": "boolean", "default": false },
                  "media": { "type": "string", "enum": ["image", "video"], "default": "image" },
                  "platforms": { "type": "array", "items": { "type": "string", "enum": ["linkedin", "x"] }, "minItems": 1, "uniqueItems": true, "default": ["linkedin", "x"] }
                }
              }
            }
          }
        },
        "responses": { "202": { "description": "Queued job" } }
      }
    },
    "/api/v1/jobs/publish-approved": {
      "post": {
        "summary": "Queue approved posts in Buffer",
        "description": "Publishes one selected approved post immediately by default; future-dated posts remain custom-scheduled. Requires explicit confirmation and fails closed when Buffer or required media hosting is not configured.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["confirm"],
                "properties": {
                  "confirm": { "type": "boolean", "const": true },
                  "post_id": { "type": "string", "maxLength": 300 },
                  "mode": { "type": "string", "enum": ["now", "queue"], "default": "now" }
                }
              }
            }
          }
        },
        "responses": { "202": { "description": "Queued publishing job" }, "503": { "description": "Publishing not configured" } }
      }
    },
    "/api/v1/jobs/animate-background": {
      "post": {
        "summary": "Generate a background-only Seedance animation for one post",
        "description": "Uses the raw generated background plate. Exact logo, typography, CTA, pricing, and disclaimers must be composited afterward.",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["post_id"],
                "properties": {
                  "post_id": { "type": "string", "maxLength": 300 },
                  "background": { "type": "string", "maxLength": 4000 },
                  "prompt": { "type": "string", "maxLength": 4000 },
                  "duration": { "type": "integer", "minimum": 8, "maximum": 12, "default": 10 },
                  "resolution": { "type": "string", "enum": ["480p", "720p", "1080p"], "default": "720p" }
                }
              }
            }
          }
        },
        "responses": { "202": { "description": "Queued animation job" }, "503": { "description": "TokenMart not configured" } }
      }
    },
    "/api/v1/jobs/metrics-collect": {
      "post": { "summary": "Queue Buffer metrics collection", "security": [{ "bearerAuth": [] }], "responses": { "202": { "description": "Queued job" } } }
    },
    "/api/v1/jobs/metrics-score": {
      "post": { "summary": "Queue metric scoring", "security": [{ "bearerAuth": [] }], "responses": { "202": { "description": "Queued job" } } }
    },
    "/api/v1/jobs/feedback-generate": {
      "post": { "summary": "Queue feedback lesson generation", "security": [{ "bearerAuth": [] }], "responses": { "202": { "description": "Queued job" } } }
    },
    "/preview": {
      "get": { "summary": "Read the existing static review preview", "responses": { "200": { "description": "HTML preview" } } }
    },
    "/media/{path}": {
      "get": {
        "summary": "Read a generated output asset",
        "security": [],
        "parameters": [{ "name": "path", "in": "path", "required": true, "schema": { "type": "string" } }],
        "responses": { "200": { "description": "Media asset" }, "404": { "description": "Not found" } }
      }
    }
  }
}
